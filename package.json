{
  "name": "eiderscript",
  "version": "0.1.0",
  "description": "EiderScript is a YAML-based framework that lets you build Vue 3 apps by defining components, Pinia stores, and Vue Router routes entirely in YAML, which compiles to standard Vue 3 code with full reactivity and internal Effect.ts handling for async operations.",
  "type": "module",
  "keywords": [
    "vue",
    "vue3",
    "pinia",
    "vue-router",
    "effect-ts",
    "effect",
    "yaml",
    "compiler",
    "declarative-ui",
    "framework",
    "state-management",
    "functional-programming",
    "zod",
    "reactivity",
    "ssr",
    "ast"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "effect": "^3.19.19",
    "expr-eval": "^2.0.2",
    "js-yaml": "^4.1.1",
    "morphdom": "^2.7.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}